---
import type { ProductSpec } from "../../data/products";

interface SpecRow {
  label: string;
  value: string;
}

interface ModelRow {
  model: string;
  capacity: string;
  dimensions: string;
  wall: string;
  lining: string;
}

interface Props {
  title?: string;
  product: ProductSpec;
  generalSpecs?: SpecRow[];
  models?: ModelRow[];
}

const {
  title = "Especificações Técnicas",
  product,
  generalSpecs,
  models,
} = Astro.props;

const defaultSpecs: SpecRow[] = generalSpecs ?? [
  { label: "Material", value: product.material },
  { label: "Capacidades", value: product.capacities.join(", ") },
  { label: "Resistência de empilhamento", value: product.stackingResistance },
  { label: "Resistência à umidade", value: product.moistureResistance },
  { label: "Compatibilidade química", value: product.chemicalCompatibility },
  { label: "Lote mínimo", value: product.minOrder },
  { label: "Prazo de entrega", value: product.leadTime },
];
---

<section class="bg-bg py-16" aria-labelledby="specs-heading">
  <div class="mx-auto max-w-content px-6">
    <h2 id="specs-heading" class="font-heading text-2xl font-semibold tracking-snug text-text-primary">
      {title}
    </h2>

    {/* General specs — key-value list, mobile-friendly */}
    <div class="mt-8 grid gap-0 divide-y divide-border-subtle rounded-lg border border-border-subtle">
      {defaultSpecs.map((spec) => (
        <div class="flex flex-col gap-1 px-6 py-4 transition-colors hover:bg-surface/50 sm:flex-row sm:gap-8">
          <span class="shrink-0 font-body text-sm font-medium text-text-muted sm:w-[220px] sm:pt-0.5">
            {spec.label}
          </span>
          <span class="font-body text-sm text-text-primary sm:text-base">
            {spec.value}
          </span>
        </div>
      ))}
    </div>

    {/* Models — table on desktop, cards on mobile */}
    {models && models.length > 0 && (
      <div class="mt-8">
        <h3 class="font-heading text-lg font-semibold text-text-primary">
          Modelos disponíveis
        </h3>

        {/* Desktop table */}
        <div class="mt-4 hidden overflow-x-auto sm:block">
          <table class="w-full text-left font-body text-sm">
            <caption class="sr-only">Tabela de modelos disponíveis com capacidade, dimensões, parede e revestimento</caption>
            <thead class="border-b border-border-subtle text-text-muted">
              <tr>
                <th scope="col" class="pb-3 pr-6 font-medium">Modelo</th>
                <th scope="col" class="pb-3 pr-6 font-medium">Capacidade</th>
                <th scope="col" class="pb-3 pr-6 font-medium">Dimensões (DxA)</th>
                <th scope="col" class="pb-3 pr-6 font-medium">Parede</th>
                <th scope="col" class="pb-3 font-medium">Revestimento</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border-subtle">
              {models.map((row) => (
                <tr class="transition-colors hover:bg-surface/50">
                  <td class="whitespace-nowrap py-3 pr-6 font-medium text-text-primary">{row.model}</td>
                  <td class="whitespace-nowrap py-3 pr-6 text-text-muted">{row.capacity}</td>
                  <td class="whitespace-nowrap py-3 pr-6 text-text-muted">{row.dimensions}</td>
                  <td class="whitespace-nowrap py-3 pr-6 text-text-muted">{row.wall}</td>
                  <td class="py-3 text-text-muted">{row.lining}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        {/* Mobile cards */}
        <div class="mt-4 grid gap-3 sm:hidden">
          {models.map((row) => (
            <div class="rounded-lg border border-border-subtle p-4">
              <p class="font-heading text-base font-semibold text-accent">{row.model}</p>
              <dl class="mt-2 grid grid-cols-2 gap-x-4 gap-y-2 font-body text-sm">
                <div>
                  <dt class="text-text-muted">Capacidade</dt>
                  <dd class="font-medium text-text-primary">{row.capacity}</dd>
                </div>
                <div>
                  <dt class="text-text-muted">Dimensões</dt>
                  <dd class="font-medium text-text-primary">{row.dimensions}</dd>
                </div>
                <div>
                  <dt class="text-text-muted">Parede</dt>
                  <dd class="font-medium text-text-primary">{row.wall}</dd>
                </div>
                <div>
                  <dt class="text-text-muted">Revestimento</dt>
                  <dd class="font-medium text-text-primary">{row.lining}</dd>
                </div>
              </dl>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
