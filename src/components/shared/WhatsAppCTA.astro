---
import { buildWhatsAppUrl } from "../../data/company";

interface Props {
  message?: string;
  label?: string;
  class?: string;
  size?: "sm" | "md" | "lg";
  microcopy?: string;
  showStatus?: boolean;
}

const {
  message,
  label = "Pedir amostra grátis",
  class: className = "",
  size = "md",
  microcopy,
  showStatus = false,
} = Astro.props;

const href = buildWhatsAppUrl(message);

const sizeClasses = {
  sm: "px-4 py-2 text-sm min-h-[44px]",
  md: "px-6 py-3 text-base min-h-[44px]",
  lg: "px-6 py-3 text-base sm:px-8 sm:py-4 sm:text-lg min-h-[44px]",
};
---

<div class="inline-flex flex-col items-center">
  {showStatus && (
    <p class="mb-2 font-body text-xs text-text-muted" data-availability-badge>
      <span class="inline-block h-2 w-2 rounded-full bg-text-muted" data-availability-dot></span>
      <span data-availability-text>Verificando horário...</span>
    </p>
  )}
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
      "inline-flex items-center gap-2 rounded-md bg-accent font-heading font-semibold text-bg-deep transition-colors hover:bg-accent-hover",
      sizeClasses[size],
      className,
    ]}
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
    {label}
  </a>
  {microcopy && (
    <p class="mt-1.5 font-body text-xs text-text-muted">{microcopy}</p>
  )}
</div>

<script>
  function initAvailabilityBadge(): void {
    const badges = document.querySelectorAll<HTMLElement>('[data-availability-badge]');
    if (!badges.length) return;

    badges.forEach((badge) => {
      const dot = badge.querySelector<HTMLElement>('[data-availability-dot]');
      const text = badge.querySelector<HTMLElement>('[data-availability-text]');
      if (!dot || !text) return;

      const now = new Date();
      const spTime = new Date(now.toLocaleString('en-US', { timeZone: 'America/Sao_Paulo' }));
      const day = spTime.getDay();
      const hour = spTime.getHours();
      const isBusinessHours = day >= 1 && day <= 5 && hour >= 8 && hour < 18;

      if (isBusinessHours) {
        dot.classList.remove('bg-text-muted');
        dot.classList.add('bg-green-500');
        text.textContent = 'Online agora';
      } else if (day === 0 || (day === 6)) {
        dot.classList.remove('bg-text-muted');
        dot.classList.add('bg-yellow-500');
        text.textContent = 'Responderemos na segunda';
      } else {
        dot.classList.remove('bg-text-muted');
        dot.classList.add('bg-yellow-500');
        text.textContent = 'Responderemos amanhã às 8h';
      }
    });
  }

  initAvailabilityBadge();
  document.addEventListener('astro:after-swap', initAvailabilityBadge);
</script>
