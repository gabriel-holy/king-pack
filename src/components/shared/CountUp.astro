---
interface Props {
  value: number;
  suffix?: string;
  duration?: number;
  decimals?: number;
  class?: string;
}

const {
  value,
  suffix = "",
  duration = 1200,
  decimals = 0,
  class: className = "",
} = Astro.props;

const displayValue = decimals > 0 ? value.toFixed(decimals).replace('.', ',') : String(value);
---

<span
  class:list={["countup", className]}
  data-countup
  data-countup-value={value}
  data-countup-suffix={suffix}
  data-countup-duration={duration}
  data-countup-decimals={decimals}
  style="font-variant-numeric: tabular-nums;"
>
  {displayValue}{suffix}
</span>

<script>
  function initCountUp(): void {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const elements = document.querySelectorAll<HTMLElement>('[data-countup]');
    if (!elements.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          const el = entry.target as HTMLElement;
          observer.unobserve(el);

          if (prefersReducedMotion) return;

          const target = Number(el.dataset.countupValue) || 0;
          const suffix = el.dataset.countupSuffix || '';
          const duration = Number(el.dataset.countupDuration) || 1200;
          const decimals = Number(el.dataset.countupDecimals) || 0;
          const start = performance.now();

          el.textContent = `0${suffix}`;

          function easeOutQuart(t: number): number {
            return 1 - Math.pow(1 - t, 4);
          }

          function formatValue(val: number): string {
            if (decimals > 0) {
              return val.toFixed(decimals).replace('.', ',');
            }
            return String(Math.round(val));
          }

          function tick(now: number): void {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            const easedProgress = easeOutQuart(progress);
            const current = easedProgress * target;
            el.textContent = `${formatValue(current)}${suffix}`;

            if (progress < 1) {
              requestAnimationFrame(tick);
            }
          }

          requestAnimationFrame(tick);
        });
      },
      { threshold: 0.15 }
    );

    elements.forEach((el) => observer.observe(el));
  }

  initCountUp();
  document.addEventListener('astro:after-swap', initCountUp);
</script>
