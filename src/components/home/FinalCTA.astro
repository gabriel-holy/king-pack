---
import WhatsAppCTA from "../shared/WhatsAppCTA.astro";
---

<section class="bg-bg-deep py-16">
  <div class="mx-auto max-w-text px-6 text-center">
    <h2 class="font-heading text-3xl font-semibold tracking-snug text-text-primary">
      Pronto para trocar de fornecedor sem risco?
    </h2>
    <p class="mt-4 font-body text-text-muted">
      Solicite uma amostra grátis. Sem compromisso, sem burocracia.
    </p>
    <div class="mt-8">
      <WhatsAppCTA label="Solicitar amostra grátis — WhatsApp" size="lg" />
    </div>
  </div>
</section>
