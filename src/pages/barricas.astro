---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductHero from "../components/product/ProductHero.astro";
import SpecsTable from "../components/product/SpecsTable.astro";
import ApplicationCards from "../components/product/ApplicationCards.astro";
import ObjectionEliminator from "../components/product/ObjectionEliminator.astro";
import WhatsAppCTA from "../components/shared/WhatsAppCTA.astro";
import { products } from "../data/products";
import { company } from "../data/company";

const product = products.find((p) => p.id === "barricas")!;

const barricaModels = [
  { model: "BP-20", capacity: "20L", dimensions: "290 x 380 mm", wall: "3mm dupla", lining: "Opcional (PE)" },
  { model: "BP-50", capacity: "50L", dimensions: "370 x 520 mm", wall: "4mm dupla", lining: "Opcional (PE)" },
  { model: "BP-100", capacity: "100L", dimensions: "450 x 650 mm", wall: "5mm tripla", lining: "Opcional (PE/Alumínio)" },
  { model: "BP-200", capacity: "200L", dimensions: "580 x 880 mm", wall: "6mm tripla", lining: "Opcional (PE/Alumínio)" },
];

const applications = [
  {
    name: "Tintas e Vernizes",
    description: "Barricas com revestimento interno para tintas à base de água e solvente. Capacidades de 20L a 200L.",
  },
  {
    name: "Grafiato e Texturas",
    description: "Embalagens reforçadas para massas e texturas de alta densidade. Fundo reforçado para empilhamento.",
  },
  {
    name: "Construção Civil",
    description: "Barricas para resinas, impermeabilizantes e aditivos. Resistência a produtos alcalinos.",
  },
];

const objections = [
  {
    title: "Amostra grátis",
    description: "Teste na sua linha antes de fechar. Sem compromisso.",
  },
  {
    title: "3 passos",
    description: "Solicita, testa, aprova. Processo simples e direto.",
  },
  {
    title: "Prazo garantido",
    description: `${product.leadTime} de produção. Entrega para todo o estado de SP.`,
  },
];

const productStructuredData = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.name,
  description: `${product.tagline}. Capacidades: ${product.capacities.join(", ")}. ${product.material}.`,
  brand: {
    "@type": "Brand",
    name: company.name,
  },
  manufacturer: {
    "@type": "Organization",
    name: company.name,
    address: {
      "@type": "PostalAddress",
      addressLocality: company.address.city,
      addressRegion: company.address.state,
      addressCountry: company.address.country,
    },
  },
  material: product.material,
  category: "Embalagens Industriais",
};
---

<BaseLayout
  title="Barricas de Papelão Industrial — Specs Técnicas e Orçamento"
  description="Barricas de papelão para indústria: capacidades 20-200L, resistência 500kg empilhamento, prazo 10 dias. Fale via WhatsApp."
  structuredData={productStructuredData}
>
  <ProductHero
    eyebrow="Produto"
    title="Barricas de Papelão"
    description="Embalagens de papelão kraft multicamadas de 20L a 200L. Projetadas para armazenamento e transporte de tintas, vernizes, resinas e produtos químicos."
    ctaMessage="Olá! Tenho interesse em barricas de papelão. Pode me enviar mais informações?"
    ctaLabel="Solicitar amostra grátis — WhatsApp"
    secondaryCtaMessage="Olá! Tenho uma dúvida técnica sobre compatibilidade dos produtos."
    secondaryCtaLabel="Dúvida técnica — WhatsApp"
  />

  <SpecsTable
    product={product}
    models={barricaModels}
  />

  <ApplicationCards applications={applications} />

  <ObjectionEliminator objections={objections} />

  <!-- CTA Final -->
  <section class="bg-bg-deep py-16">
    <div class="mx-auto max-w-text px-6 text-center">
      <h2 class="font-heading text-3xl font-semibold tracking-snug text-text-primary">
        Precisa de barricas sob medida?
      </h2>
      <p class="mt-4 font-body text-text-muted">
        Informe volume, quantidade e aplicação. Respondemos em até 2 horas.
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <WhatsAppCTA
          message="Olá! Tenho interesse em barricas de papelão. Pode me enviar mais informações?"
          label="Pedir Orçamento — WhatsApp"
          size="lg"
        />
        <WhatsAppCTA
          message="Olá! Tenho uma dúvida técnica sobre compatibilidade dos produtos."
          label="Dúvida técnica — WhatsApp"
          size="md"
        />
      </div>
    </div>
  </section>
</BaseLayout>
