---
import WhatsAppCTA from "../shared/WhatsAppCTA.astro";
---

<section class="bg-bg-deep py-20">
  <div class="mx-auto max-w-content px-6">
    <div class="max-w-3xl">
      <p class="font-body text-xs font-medium uppercase tracking-widest text-accent">
        Fabricante Industrial — Americana, SP
      </p>
      <h1 class="mt-4 font-heading text-4xl font-bold leading-tight tracking-tight text-text-primary sm:text-[clamp(2.25rem,5vw,3.75rem)]">
        Embalagens industriais que sua produção exige
      </h1>
      <p class="mt-6 font-body text-lg text-text-muted">
        Barricas de papelão e baldes plásticos para indústrias de tintas, vernizes, químicos e agroquímicos. 22 anos em Americana-SP.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <WhatsAppCTA label="Solicitar Orçamento via WhatsApp" size="md" />
        <a
          href="/barricas"
          class="inline-flex min-h-[44px] items-center rounded-md border border-border-subtle px-6 py-3 font-heading text-sm font-semibold text-text-primary transition-colors hover:bg-surface"
        >
          Ver Produtos
        </a>
      </div>
    </div>
  </div>
</section>
