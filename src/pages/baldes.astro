---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductHero from "../components/product/ProductHero.astro";
import SpecsTable from "../components/product/SpecsTable.astro";
import ApplicationCards from "../components/product/ApplicationCards.astro";
import ObjectionEliminator from "../components/product/ObjectionEliminator.astro";
import WhatsAppCTA from "../components/shared/WhatsAppCTA.astro";
import { products } from "../data/products";
import { company } from "../data/company";

const product = products.find((p) => p.id === "baldes")!;

const baldeModels = [
  { model: "BL-3.6", capacity: "3,6L", dimensions: "190 x 170 mm", wall: "1.2mm PP", lining: "Natural" },
  { model: "BL-5", capacity: "5L", dimensions: "210 x 190 mm", wall: "1.2mm PP", lining: "Natural" },
  { model: "BL-10", capacity: "10L", dimensions: "260 x 250 mm", wall: "1.5mm PEAD", lining: "Natural / Colorido" },
  { model: "BL-18", capacity: "18L", dimensions: "310 x 340 mm", wall: "1.8mm PEAD", lining: "Natural / Colorido" },
  { model: "BL-20", capacity: "20L", dimensions: "320 x 360 mm", wall: "2.0mm PEAD", lining: "Natural / Colorido" },
];

const applications = [
  {
    name: "Tintas e Massas",
    description: "Vedação hermética que elimina vazamento de tintas à base de água e solvente. Seu cliente recebe o produto intacto.",
  },
  {
    name: "Químicos Industriais",
    description: "PEAD que resiste a ácidos, bases e solventes sem deformar. Aprovado para transporte de químicos perigosos — sua logística segura.",
  },
  {
    name: "Agroquímicos",
    description: "Vedação total para defensivos e fertilizantes líquidos. Zero vazamento do campo ao ponto de venda.",
  },
  {
    name: "Produtos para Construção",
    description: "Empilhamento fácil em obra, manuseio com uma mão só. Ideal para impermeabilizantes, resinas e aditivos.",
  },
];

const objections = [
  {
    title: "Teste antes de decidir",
    description: "Receba uma amostra grátis em até 48h. Teste na sua linha de produção real. Se não aprovar, zero custo.",
  },
  {
    title: "Simples como deve ser",
    description: "WhatsApp → amostra em 48h → primeiro pedido. Sem burocracia, sem licitação, sem enrolação.",
  },
  {
    title: "Prazo garantido",
    description: `Produção em ${product.leadTime} com entrega na porta da sua fábrica em SP. Prazo garantido em contrato.`,
  },
];

const siteUrl = "https://barricasindustriais.com";

const productSchema = {
  "@type": "Product",
  name: product.name,
  description: `${product.tagline}. Capacidades: ${product.capacities.join(", ")}. ${product.material}.`,
  brand: {
    "@type": "Brand",
    name: company.name,
  },
  manufacturer: {
    "@type": "Organization",
    name: company.name,
    address: {
      "@type": "PostalAddress",
      addressLocality: company.address.city,
      addressRegion: company.address.state,
      addressCountry: company.address.country,
    },
  },
  material: product.material,
  category: "Embalagens Industriais",
  offers: {
    "@type": "Offer",
    availability: "https://schema.org/InStock",
    priceSpecification: {
      "@type": "PriceSpecification",
      priceCurrency: "BRL",
    },
    areaServed: {
      "@type": "State",
      name: "São Paulo",
    },
  },
};

const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: "Baldes Plásticos" },
  ],
};

const faqSchema = {
  "@type": "FAQPage",
  mainEntity: objections.map((o) => ({
    "@type": "Question",
    name: o.title,
    acceptedAnswer: { "@type": "Answer", text: o.description },
  })),
};

const productStructuredData = {
  "@context": "https://schema.org",
  "@graph": [productSchema, breadcrumbSchema, faqSchema],
};
---

<BaseLayout
  title="Baldes Plásticos Industriais 3,6-20L · Amostra Grátis · King Pack"
  description="Baldes PP e PEAD de 3,6L a 20L. Vedação hermética, resistência química comprovada. Amostra grátis em 48h. Fábrica em Americana-SP."
  type="product"
  structuredData={productStructuredData}
>
  <ProductHero
    eyebrow="Balde Plástico Industrial"
    title="Baldes que Vedam, Empilham e Não Vazam"
    description="PP e PEAD de 3,6L a 20L. Vedação hermética testada, empilhamento até 300kg e resistência química para tintas, agroquímicos e químicos industriais. Usados por 500+ indústrias em SP."
    ctaMessage="Olá! Quero receber uma amostra grátis de balde plástico. Minha necessidade é [volume/produto]."
    ctaLabel="Receber amostra grátis"
    secondaryCtaMessage="Olá! Tenho uma dúvida técnica sobre compatibilidade dos baldes plásticos."
    secondaryCtaLabel="Dúvida técnica — WhatsApp"
    image="/images/products/production-line-bottles.jpg"
    imageAlt="Linha de produção industrial com containers em série"
    imageWidth={1200}
    imageHeight={800}
  />

  <SpecsTable
    product={product}
    models={baldeModels}
  />

  <ApplicationCards applications={applications} />

  <ObjectionEliminator objections={objections} />

  <!-- CTA Final -->
  <section class="bg-bg-deep py-16">
    <div class="mx-auto max-w-text px-6 text-center">
      <h2 class="font-heading text-3xl font-semibold tracking-snug text-text-primary">
        Cada balde que vaza é cliente que você perde
      </h2>
      <p class="mt-4 font-body text-text-muted">
        Manda volume, quantidade e aplicação no WhatsApp. Resposta em até 2 horas — direto com o dono da fábrica.
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <WhatsAppCTA
          message="Olá! Quero receber uma amostra grátis de balde plástico. Minha necessidade é [volume/produto]."
          label="Pedir Orçamento — WhatsApp"
          size="lg"
        />
        <WhatsAppCTA
          message="Olá! Tenho uma dúvida técnica sobre compatibilidade dos baldes plásticos."
          label="Dúvida técnica — WhatsApp"
          size="md"
        />
      </div>
    </div>
  </section>
</BaseLayout>
