---
import { company } from "../../data/company";

const metrics = [
  { value: `${company.metrics.yearsInMarket}+`, label: "Anos fabricando sem parar" },
  { value: `${company.metrics.activeClients}+`, label: "Indústrias confiam em nós" },
  { value: `${company.metrics.deliveryHours}h`, label: "Da fábrica até você" },
  { value: company.metrics.defectRate, label: "Defeitos no transporte" },
];
---

<section class="bg-bg py-12">
  <div class="mx-auto grid max-w-content grid-cols-2 gap-8 px-6 md:grid-cols-4">
    {metrics.map((metric) => (
      <div class="text-center">
        <p class="font-heading text-xl font-bold text-accent">{metric.value}</p>
        <p class="mt-1 font-body text-sm text-text-muted">{metric.label}</p>
      </div>
    ))}
  </div>
</section>
