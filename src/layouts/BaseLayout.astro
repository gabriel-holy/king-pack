---
import SEOHead from "../components/shared/SEOHead.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import WhatsAppButton from "../components/layout/WhatsAppButton.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  structuredData?: Record<string, unknown>;
}

const { title, description, ogImage, structuredData } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      structuredData={structuredData}
    />
  </head>
  <body class="min-h-screen bg-bg font-body text-text-primary antialiased">
    <Header />

    <main>
      <slot />
    </main>

    <Footer />
    <WhatsAppButton />
  </body>
</html>
