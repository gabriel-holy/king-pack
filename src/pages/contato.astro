---
import BaseLayout from "../layouts/BaseLayout.astro";
import WhatsAppCTA from "../components/shared/WhatsAppCTA.astro";
import { company } from "../data/company";
---

<BaseLayout
  title="Contato — Fábrica de Barricas e Baldes, Americana SP"
  description="Fale com a fábrica via WhatsApp: (19) 99258-0247. Americana, SP."
>
  <!-- Hero -->
  <section class="bg-bg-deep py-16">
    <div class="mx-auto max-w-content px-6 text-center">
      <h1 class="font-heading text-4xl font-bold tracking-tight text-text-primary">
        Fale com a gente
      </h1>
      <p class="mt-4 font-body text-lg text-text-muted">
        Resposta em até 2 horas — segunda a sexta
      </p>
    </div>
  </section>

  <section class="bg-bg py-16">
    <div class="mx-auto max-w-content px-6">
      <div class="mx-auto grid max-w-4xl gap-12 md:grid-cols-2">
        <!-- WhatsApp Card -->
        <div class="rounded-lg border border-border-subtle bg-surface p-8 text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-[#25D366]">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="white" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <p class="mt-4 font-heading text-xl font-semibold text-text-primary">{company.phone}</p>
          <p class="mt-2 font-body text-sm text-text-muted">Prefere chamar diretamente?</p>
          <WhatsAppCTA
            message="Olá! Gostaria de falar com a fábrica."
            label="Abrir WhatsApp agora"
            size="md"
            class="mt-6"
          />
        </div>

        <!-- Info -->
        <div>
          <h2 class="font-heading text-xl font-semibold text-text-primary">Informações</h2>
          <dl class="mt-6 space-y-4 font-body text-sm">
            <div>
              <dt class="font-medium text-text-primary">Endereço</dt>
              <dd class="text-text-muted">
                {company.address.street} - {company.address.neighborhood}<br />
                {company.address.city} - {company.address.state}, {company.address.zip}
              </dd>
            </div>
            <div>
              <dt class="font-medium text-text-primary">Telefone / WhatsApp</dt>
              <dd class="text-text-muted">{company.phone}</dd>
            </div>
            <div>
              <dt class="font-medium text-text-primary">E-mail</dt>
              <dd class="text-text-muted">{company.email}</dd>
            </div>
            <div>
              <dt class="font-medium text-text-primary">Horário</dt>
              <dd class="text-text-muted">{company.hours}</dd>
            </div>
            <div>
              <dt class="font-medium text-text-primary">CNPJ</dt>
              <dd class="text-text-muted">{company.cnpj}</dd>
            </div>
          </dl>
        </div>
      </div>

      <!-- Map placeholder -->
      <div class="mx-auto mt-12 max-w-4xl">
        <h2 class="font-heading text-xl font-semibold text-text-primary">Localização</h2>
        <div class="mt-6 flex h-64 items-center justify-center rounded-lg border border-border-subtle bg-surface font-body text-sm text-text-muted">
          Mapa — Americana, SP (Google Maps embed)
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
