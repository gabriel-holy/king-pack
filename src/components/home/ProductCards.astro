---
import { Image } from "astro:assets";
import SectionHeader from "../shared/SectionHeader.astro";
import warehousePackagesImg from "../../assets/images/products/warehouse-packages.jpg";
import chemicalWorkerImg from "../../assets/images/products/chemical-worker.jpg";

const products = [
  {
    href: "/barricas",
    image: warehousePackagesImg,
    imageAlt: "Pacotes industriais empilhados em galpão de distribuição",
    name: "Barricas de Papelão",
    description: "14L a 20L. Empilhamento de até 3 barricas e zero vazamento no transporte. Para tintas, vernizes e químicos.",
  },
  {
    href: "/baldes",
    image: chemicalWorkerImg,
    imageAlt: "Operador industrial manuseando container químico com EPI",
    name: "Baldes Plásticos",
    description: "3,6L a 20L. Vedação hermética, empilhamento seguro e resistência química comprovada. Para tintas, massas e agroquímicos.",
  },
];
---

<section class="bg-surface py-16">
  <div class="mx-auto max-w-content px-6">
    <SectionHeader
      title="Qual embalagem sua produção precisa?"
      subtitle="Escolha o tipo e veja as especificações técnicas completas — sem cadastro."
    />
    <div class="mt-12 grid gap-8 md:grid-cols-2" data-stagger-parent>
      {products.map((product) => (
        <a href={product.href} class="card-lift group rounded-lg border border-border-subtle bg-bg p-8" data-fade-up>
          <div class="mb-4 overflow-hidden rounded-lg bg-surface-2">
            <img
              src={product.image}
              alt={product.imageAlt}
              width={product.imageWidth}
              height={product.imageHeight}
              loading="lazy"
              class="aspect-[4/3] w-full object-cover transition-transform duration-300 group-hover:scale-105"
            />
          </div>
          <h3 class="font-heading text-xl font-semibold text-text-primary group-hover:text-accent">
            {product.name}
          </h3>
          <p class="mt-2 font-body text-sm text-text-muted">
            {product.description}
          </p>
          <span class="mt-4 inline-block font-body text-sm font-medium text-accent">
            Ver specs · Amostra grátis &rarr;
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
