---
import { ClientRouter } from "astro:transitions";
import SEOHead from "../components/shared/SEOHead.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import WhatsAppButton from "../components/layout/WhatsAppButton.astro";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  type?: "website" | "product";
  structuredData?: Record<string, unknown>;
  noindex?: boolean;
}

const { title, description, ogImage, type, structuredData, noindex } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.gstatic.com/s/spacegrotesk/v16/V8mDoQDjQSkFtoMM3T6r8E7mPb54C_k3HqUtEw.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500&display=swap" /></noscript>
    <link rel="manifest" href="/manifest.json" />
    <ClientRouter />
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      type={type}
      structuredData={structuredData}
      noindex={noindex}
    />
  </head>
  <body class="min-h-screen bg-bg font-body text-text-primary antialiased">
    <div id="scroll-progress" aria-hidden="true"></div>
    <Header />

    <main>
      <slot />
    </main>

    <Footer />
    <WhatsAppButton />
    <Analytics />
    <SpeedInsights />

    <script>
      import { initFadeUp } from "../utils/fadeUp";

      function initScrollProgress(): void {
        if (CSS.supports('animation-timeline', 'scroll()')) return;
        const bar = document.getElementById('scroll-progress');
        if (!bar) return;
        window.addEventListener('scroll', () => {
          const h = document.documentElement;
          const pct = h.scrollTop / (h.scrollHeight - h.clientHeight);
          bar.style.transform = `scaleX(${pct})`;
        }, { passive: true });
      }

      function initTextReveal(): void {
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReducedMotion) return;

        const elements = document.querySelectorAll<HTMLElement>('.text-reveal');
        if (!elements.length) return;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const el = entry.target as HTMLElement;
              const delay = el.getAttribute('data-reveal-delay');
              if (delay) {
                setTimeout(() => el.classList.add('revealed'), Number(delay));
              } else {
                el.classList.add('revealed');
              }
              observer.unobserve(el);
            });
          },
          { threshold: 0.15 }
        );
        elements.forEach((el) => observer.observe(el));
      }

      function initAll(): void {
        initFadeUp();
        initScrollProgress();
        initTextReveal();
      }

      initAll();
      document.addEventListener('astro:after-swap', initAll);
    </script>
  </body>
</html>
