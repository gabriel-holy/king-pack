---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { company } from "../../data/company";

const posts = (await getCollection("blog")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const siteUrl = "https://barricasindustriais.com";

const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: "Blog" },
  ],
};

const blogSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Blog",
      name: `Blog ${company.name}`,
      description:
        "Conteúdo técnico sobre embalagens industriais: barricas de papelão, baldes plásticos, compatibilidade química e logística.",
      url: `${siteUrl}/blog`,
      publisher: {
        "@type": "Organization",
        name: company.name,
      },
    },
    breadcrumbSchema,
  ],
};
---

<BaseLayout
  title={`Blog — Embalagens Industriais | ${company.name}`}
  description="Conteúdo técnico sobre embalagens industriais: barricas de papelão, baldes plásticos, compatibilidade química e logística."
  structuredData={blogSchema}
>
  <section class="mx-auto max-w-content px-6 py-16">
    <!-- Header -->
    <div class="mb-12 max-w-text">
      <p class="font-body text-xs font-medium uppercase tracking-widest text-accent">
        Blog King Pack
      </p>
      <h1 class="mt-3 font-heading text-4xl font-bold tracking-tight text-text-primary">
        Embalagens Industriais
      </h1>
      <p class="mt-4 font-body text-base text-text-muted">
        Conteúdo técnico sobre barricas de papelão, baldes plásticos, compatibilidade química, legislação e logística industrial.
      </p>
    </div>

    <!-- Posts grid -->
    {posts.length > 0 ? (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <a
            href={`/blog/${post.data.slug}`}
            class="group flex flex-col rounded-lg border border-border-subtle bg-surface p-6 transition-colors hover:border-accent/30"
          >
            <div class="mb-3 flex flex-wrap gap-2">
              {post.data.tags.slice(0, 2).map((tag: string) => (
                <span class="rounded-sm bg-[rgba(77,171,247,0.10)] px-2 py-0.5 font-body text-xs font-medium text-accent">
                  {tag}
                </span>
              ))}
            </div>
            <h2 class="font-heading text-lg font-semibold tracking-snug text-text-primary group-hover:text-accent transition-colors">
              {post.data.title}
            </h2>
            <p class="mt-2 flex-1 font-body text-sm text-text-muted line-clamp-3">
              {post.data.description}
            </p>
            <div class="mt-4 flex items-center gap-3 font-body text-xs text-text-muted">
              <time datetime={post.data.date}>
                {new Date(post.data.date + "T00:00:00").toLocaleDateString("pt-BR", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </time>
              <span aria-hidden="true">·</span>
              <span>{post.data.readingTime} min</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="rounded-lg border border-border-subtle bg-surface p-12 text-center">
        <p class="font-body text-base text-text-muted">
          Em breve teremos conteúdo técnico sobre embalagens industriais.
        </p>
      </div>
    )}
  </section>
</BaseLayout>
