---
import BaseLayout from "../layouts/BaseLayout.astro";
import WhatsAppCTA from "../components/shared/WhatsAppCTA.astro";
import { company } from "../data/company";

const siteUrl = "https://barricasindustriais.com";

const mapsQuery = encodeURIComponent(
  `${company.address.street}, ${company.address.neighborhood}, ${company.address.city} - ${company.address.state}, ${company.address.zip}`
);
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`;

const contactPageSchema = {
  "@type": "ContactPage",
  name: `Contato — ${company.name}`,
  description: "Fale com a fábrica via WhatsApp",
  mainEntity: {
    "@type": "LocalBusiness",
    name: company.name,
    telephone: company.phone,
    email: company.email,
    address: {
      "@type": "PostalAddress",
      streetAddress: `${company.address.street} - ${company.address.neighborhood}`,
      addressLocality: company.address.city,
      addressRegion: company.address.state,
      postalCode: company.address.zip,
      addressCountry: company.address.country,
    },
  },
};

const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: "Contato" },
  ],
};

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [contactPageSchema, breadcrumbSchema],
};
---

<BaseLayout
  title="Contato — King Pack · Fábrica de Barricas e Baldes, Americana SP"
  description="Fale direto com o dono da fábrica via WhatsApp: (19) 99258-0247. Resposta em até 2h. Americana, SP."
  ogImage="/images/og/og-contato.jpg"
  structuredData={structuredData}
>
  <!-- Hero -->
  <section class="bg-bg-deep py-16 md:py-20">
    <div class="mx-auto max-w-content px-6 text-center">
      <p class="font-body text-xs font-medium uppercase tracking-widest text-accent">
        Fale com o dono da fábrica
      </p>
      <h1 class="mt-3 font-heading text-[clamp(1.75rem,5vw,2.25rem)] font-bold tracking-tight text-text-primary">
        Resposta real, de quem fabrica de verdade
      </h1>
      <p class="mt-4 font-body text-lg text-text-muted">
        WhatsApp respondido em até 2 horas. Segunda a sexta, 8h às 18h.
      </p>
    </div>
  </section>

  <!-- WhatsApp Card (destaque principal) -->
  <section class="bg-bg py-16">
    <div class="mx-auto max-w-content px-6">
      <div class="mx-auto max-w-lg rounded-lg border border-accent/20 bg-surface p-8 text-center md:p-10">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-[#25D366]">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="white" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </div>
        <p class="mt-5 font-heading text-2xl font-semibold text-text-primary">
          {company.phone}
        </p>
        <p class="mt-2 font-body text-sm text-text-muted">
          Sem robô, sem fila. Você fala direto com quem decide.
        </p>
        <WhatsAppCTA
          message="Olá! Vi o site da King Pack e quero falar sobre embalagens para minha produção."
          label="Chamar no WhatsApp agora"
          size="lg"
          class="mt-6 w-full justify-center"
        />
      </div>
    </div>
  </section>

  <!-- Endereço + Mapa -->
  <section class="bg-surface py-16">
    <div class="mx-auto max-w-content px-6">
      <div class="mx-auto grid max-w-4xl gap-12 md:grid-cols-2">
        <!-- Endereço e link Google Maps -->
        <div>
          <h2 class="font-heading text-xl font-semibold text-text-primary">
            Localização
          </h2>
          <address class="mt-6 not-italic">
            <p class="font-body text-base text-text-primary">
              {company.address.street} — {company.address.neighborhood}
            </p>
            <p class="mt-1 font-body text-base text-text-primary">
              {company.address.city} — {company.address.state}, {company.address.zip}
            </p>
          </address>
          <a
            href={mapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex min-h-[44px] items-center gap-2 rounded-md border border-border-subtle px-4 py-2 font-body text-sm font-medium text-accent transition-colors hover:border-accent hover:text-accent-hover"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            Abrir no Google Maps
          </a>
          <div class="mt-6 rounded-lg border border-border-subtle bg-bg p-4">
            <p class="font-body text-xs text-text-muted">
              {company.hours}
            </p>
          </div>
        </div>

        <!-- Dados da Empresa -->
        <div>
          <h2 class="font-heading text-xl font-semibold text-text-primary">
            Dados da Empresa
          </h2>
          <dl class="mt-6 space-y-4 font-body text-sm">
            <div>
              <dt class="font-medium text-text-muted">Telefone / WhatsApp</dt>
              <dd class="mt-1 text-text-primary">{company.phone}</dd>
            </div>
            <div>
              <dt class="font-medium text-text-muted">E-mail</dt>
              <dd class="mt-1 text-text-primary">{company.email}</dd>
            </div>
            <div>
              <dt class="font-medium text-text-muted">Horário</dt>
              <dd class="mt-1 text-text-primary">{company.hours}</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
