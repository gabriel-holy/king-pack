---
import type { Testimonial } from "../../data/testimonials";

interface Props {
  testimonial: Testimonial;
}

const { testimonial } = Astro.props;
---

<section class="bg-surface py-8">
  <div class="mx-auto max-w-text px-6">
    <blockquote class="text-center">
      <p class="font-body text-base italic text-text-primary leading-relaxed">
        &ldquo;{testimonial.quote}&rdquo;
      </p>
      <footer class="mt-3 font-body text-sm text-text-muted">
        <strong class="font-medium text-text-primary">{testimonial.author}</strong>
        <span class="mx-1">&middot;</span>
        {testimonial.role}, {testimonial.company}
      </footer>
    </blockquote>
  </div>
</section>
