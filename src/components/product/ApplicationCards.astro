---
interface Application {
  name: string;
  description: string;
}

interface Props {
  title?: string;
  applications: Application[];
}

const {
  title = "Aplicações por Setor",
  applications,
} = Astro.props;
---

<section class="bg-surface py-16">
  <div class="mx-auto max-w-content px-6">
    <h2 class="font-heading text-2xl font-semibold tracking-snug text-text-primary">
      {title}
    </h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-stagger-parent>
      {applications.map((app) => (
        <div class="card-lift rounded-lg border border-border-subtle bg-bg p-6" data-fade-up>
          <h3 class="font-heading text-lg font-semibold text-text-primary">
            {app.name}
          </h3>
          <p class="mt-2 font-body text-sm text-text-muted">
            {app.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
