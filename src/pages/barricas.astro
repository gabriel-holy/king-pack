---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductHero from "../components/product/ProductHero.astro";
import SpecsTable from "../components/product/SpecsTable.astro";
import ApplicationCards from "../components/product/ApplicationCards.astro";
import ObjectionEliminator from "../components/product/ObjectionEliminator.astro";
import WhatsAppCTA from "../components/shared/WhatsAppCTA.astro";
import { products } from "../data/products";
import { company } from "../data/company";

const product = products.find((p) => p.id === "barricas")!;

const barricaModels = [
  { model: "BP-14", capacity: "14L", dimensions: "260 x 320 mm", wall: "3mm dupla", lining: "Opcional (PE)" },
  { model: "BP-16", capacity: "16L", dimensions: "270 x 340 mm", wall: "3mm dupla", lining: "Opcional (PE)" },
  { model: "BP-18", capacity: "18L", dimensions: "280 x 360 mm", wall: "3mm dupla", lining: "Opcional (PE)" },
  { model: "BP-20", capacity: "20L", dimensions: "290 x 380 mm", wall: "3mm dupla", lining: "Opcional (PE)" },
];

const applications = [
  {
    name: "Tintas e Vernizes",
    description: "Revestimento interno PE ou alumínio que protege tinta à base de água. Empresas como a sua já despacham 10.000+ barricas/mês com zero perda.",
  },
  {
    name: "Grafiato e Texturas",
    description: "Fundo reforçado que aguenta o peso do grafiato sem deformar. Empilhamento seguro de até 3 barricas — do estoque ao caminhão.",
  },
  {
    name: "Construção Civil",
    description: "Resistência comprovada a resinas, impermeabilizantes e aditivos alcalinos. Revestimento de alumínio para pH extremo.",
  },
];

const objections = [
  {
    title: "Teste antes de decidir",
    description: "Receba uma amostra grátis em até 48h. Teste na sua linha de produção real. Se não aprovar, zero custo.",
  },
  {
    title: "Simples como deve ser",
    description: "WhatsApp → amostra em 48h → primeiro pedido. Sem burocracia, sem licitação, sem enrolação.",
  },
  {
    title: "Prazo garantido",
    description: `Produção em ${product.leadTime} com entrega na porta da sua fábrica em SP. Prazo garantido em contrato.`,
  },
];

const siteUrl = "https://barricasindustriais.com";

const productSchema = {
  "@type": "Product",
  name: product.name,
  description: `${product.tagline}. Capacidades: ${product.capacities.join(", ")}. ${product.material}.`,
  brand: {
    "@type": "Brand",
    name: company.name,
  },
  manufacturer: {
    "@type": "Organization",
    name: company.name,
    address: {
      "@type": "PostalAddress",
      addressLocality: company.address.city,
      addressRegion: company.address.state,
      addressCountry: company.address.country,
    },
  },
  material: product.material,
  category: "Embalagens Industriais",
  offers: {
    "@type": "Offer",
    availability: "https://schema.org/InStock",
    priceSpecification: {
      "@type": "PriceSpecification",
      priceCurrency: "BRL",
    },
    areaServed: {
      "@type": "State",
      name: "São Paulo",
    },
  },
};

const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: "Barricas de Papelão" },
  ],
};

const faqSchema = {
  "@type": "FAQPage",
  mainEntity: objections.map((o) => ({
    "@type": "Question",
    name: o.title,
    acceptedAnswer: { "@type": "Answer", text: o.description },
  })),
};

const productStructuredData = {
  "@context": "https://schema.org",
  "@graph": [productSchema, breadcrumbSchema, faqSchema],
};
---

<BaseLayout
  title="Barricas de Papelão Industrial 14-20L · Amostra Grátis · King Pack"
  description="Barricas de papelão maculatura 14-20L com empilhamento de até 3 barricas. Amostra grátis em 48h. Fábrica própria em Americana-SP. Fale no WhatsApp."
  type="product"
  structuredData={productStructuredData}
>
  <ProductHero
    eyebrow="Barrica de Papelão"
    title="Barricas de Papelão de 14 a 20L. Aguentam o peso da sua produção."
    description="Papelão maculatura com capa kraft de 14L a 20L. Empilhamento de até 3 barricas, zero vazamento no transporte, tampa e fundo de plástico. Testada por 500+ indústrias de tintas, químicos e agroquímicos."
    ctaMessage="Olá! Quero receber uma amostra grátis de barrica de papelão. Minha necessidade é [volume/produto]."
    ctaLabel="Receber amostra grátis"
    secondaryCtaMessage="Olá! Tenho uma dúvida técnica sobre compatibilidade dos produtos."
    secondaryCtaLabel="Dúvida técnica — WhatsApp"
    image="/images/products/warehouse-pallets.jpg"
    imageAlt="Produtos embalados em pallets dentro de galpão industrial"
    imageWidth={1200}
    imageHeight={800}
  />

  <SpecsTable
    product={product}
    models={barricaModels}
  />

  <ApplicationCards applications={applications} />

  <ObjectionEliminator objections={objections} />

  <!-- CTA Final -->
  <section class="bg-bg-deep py-16">
    <div class="mx-auto max-w-text px-6 text-center">
      <h2 class="font-heading text-3xl font-semibold tracking-snug text-text-primary">
        Teste na sua linha antes de decidir. Amostra em 48h.
      </h2>
      <p class="mt-4 font-body text-text-muted">
        Manda volume, quantidade e aplicação no WhatsApp. Resposta em até 2 horas — direto com o dono da fábrica.
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <WhatsAppCTA
          message="Olá! Quero receber uma amostra grátis de barrica de papelão. Minha necessidade é [volume/produto]."
          label="Pedir Orçamento — WhatsApp"
          size="lg"
        />
        <WhatsAppCTA
          message="Olá! Tenho uma dúvida técnica sobre compatibilidade dos produtos."
          label="Dúvida técnica — WhatsApp"
          size="md"
        />
      </div>
    </div>
  </section>
</BaseLayout>
