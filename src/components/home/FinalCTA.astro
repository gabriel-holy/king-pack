---
import WhatsAppCTA from "../shared/WhatsAppCTA.astro";
import MagneticButton from "../shared/MagneticButton.astro";
---

<section class="bg-bg-deep py-16">
  <div class="mx-auto max-w-text px-6 text-center" data-fade-up>
    <h2 class="font-heading text-3xl font-semibold tracking-snug text-text-primary">
      A próxima remessa não espera
    </h2>
    <p class="mt-4 font-body text-text-muted">
      Peça uma amostra grátis agora. Sem cadastro, sem compromisso — só WhatsApp.
    </p>
    <div class="mt-8 flex justify-center">
      <MagneticButton>
        <WhatsAppCTA label="Mandar mensagem agora" size="lg" message="Olá! Vi o site da King Pack e quero receber uma amostra grátis." microcopy="Resposta em até 2h em horário comercial" />
      </MagneticButton>
    </div>
  </div>
</section>
