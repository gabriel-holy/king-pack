---
import { company, buildWhatsAppUrl } from "../../data/company";

const whatsappUrl = buildWhatsAppUrl();
---

<footer class="border-t border-border-subtle bg-bg-deep">
  <div class="mx-auto max-w-content px-6 py-12">
    <div class="grid gap-8 md:grid-cols-[1.2fr_0.8fr_1fr]">
      <!-- Company -->
      <div>
        <h3 class="font-heading text-lg font-semibold tracking-snug text-text-primary">
          {company.name} — Embalagens Industriais
        </h3>
        <p class="mt-3 font-body text-sm text-text-muted">
          {company.metrics.yearsInMarket} anos fabricando embalagens que não falham. {company.metrics.activeClients}+ indústrias em SP confiam na King Pack.
        </p>
      </div>

      <!-- Products -->
      <nav aria-label="Produtos">
        <h4 class="font-body text-xs font-medium uppercase tracking-wider text-text-muted">
          Produtos
        </h4>
        <ul class="mt-3 space-y-2">
          <li>
            <a href="/barricas" class="inline-flex min-h-[44px] items-center font-body text-sm text-text-muted transition-colors hover:text-accent">
              Barricas de Papelão
            </a>
          </li>
          <li>
            <a href="/baldes" class="inline-flex min-h-[44px] items-center font-body text-sm text-text-muted transition-colors hover:text-accent">
              Baldes Plásticos
            </a>
          </li>
          <li>
            <a href="/blog" class="inline-flex min-h-[44px] items-center font-body text-sm text-text-muted transition-colors hover:text-accent">
              Blog
            </a>
          </li>
        </ul>
      </nav>

      <!-- Contact -->
      <div>
        <h4 class="font-body text-xs font-medium uppercase tracking-wider text-text-muted">
          Contato
        </h4>
        <ul class="mt-3 space-y-2 font-body text-sm text-text-muted">
          <li>
            {company.address.street} — {company.address.neighborhood}
          </li>
          <li>
            {company.address.city} - {company.address.state}, {company.address.zip}
          </li>
          <li>
            <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="inline-flex min-h-[44px] items-center transition-colors hover:text-accent">
              {company.phone}
              <span class="sr-only"> (abre em nova aba)</span>
            </a>
          </li>
          <li>{company.hours}</li>
        </ul>
      </div>
    </div>

    <div class="mt-10 border-t border-border-subtle pt-8 text-center font-body text-xs text-text-muted">
      &copy; <span id="copyright-year">{new Date().getFullYear()}</span> {company.name}. Todos os direitos reservados.
    </div>

    <script>
      document.getElementById("copyright-year")!.textContent = String(new Date().getFullYear());
    </script>
  </div>
</footer>
