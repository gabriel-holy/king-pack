---
import { Image } from "astro:assets";
import SectionHeader from "../shared/SectionHeader.astro";
import barricaBlueprintImg from "../../assets/images/products/barrica-blueprint.png";
import baldeBlueprintImg from "../../assets/images/products/balde-blueprint.png";

const products = [
  {
    href: "/barricas",
    image: barricaBlueprintImg,
    imageAlt: "Desenho técnico de barrica de papelão industrial",
    name: "Barricas de Papelão",
    description: "14L a 20L. Empilhamento de até 3 barricas e zero vazamento no transporte. Para tintas à base de água, texturas e construção civil.",
    imgClass: "max-h-[260px]",
  },
  {
    href: "/baldes",
    image: baldeBlueprintImg,
    imageAlt: "Desenho técnico de balde plástico industrial",
    name: "Baldes Plásticos",
    description: "3,6L a 20L. Vedação hermética, empilhamento seguro e resistência química comprovada. Para tintas, massas e produtos industriais.",
    imgClass: "max-h-[300px]",
  },
];
---

<section class="bg-surface py-16" aria-labelledby="products-heading">
  <div class="mx-auto max-w-content px-6">
    <SectionHeader
      title="Qual embalagem sua produção precisa?"
      subtitle="Escolha o tipo e veja as especificações técnicas completas — sem cadastro."
      id="products-heading"
    />
    <div class="mt-12 grid gap-8 md:grid-cols-2" data-stagger-parent>
      {products.map((product) => (
        <a href={product.href} class="card-lift group rounded-lg border border-border-subtle bg-bg p-8" data-fade-up>
          <div class="mb-4 flex h-[350px] items-center justify-center overflow-hidden rounded-lg bg-bg">
            <Image
              src={product.image}
              alt={product.imageAlt}
              width={600}
              height={450}
              format="webp"
              quality={80}
              loading="lazy"
              decoding="async"
              class:list={[product.imgClass, "w-auto object-contain invert mix-blend-screen transition-transform duration-300 group-hover:scale-105"]}
            />
          </div>
          <h3 class="font-heading text-xl font-semibold text-text-primary group-hover:text-accent">
            {product.name}
          </h3>
          <p class="mt-2 font-body text-sm text-text-muted">
            {product.description}
          </p>
          <span class="mt-4 inline-block font-body text-sm font-medium text-accent">
            Ver specs · Amostra grátis &rarr;
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
