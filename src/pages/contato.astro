---
import Layout from "../layouts/Layout.astro";

const WHATSAPP_NUMBER = "5519999999999";
const WHATSAPP_URL = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent("Olá! Vim pelo site e gostaria de conversar sobre embalagens.")}`;
---

<Layout
  title="Contato | Fábrica de Barricas e Baldes"
  description="Entre em contato com a Fábrica de Barricas e Baldes em Americana-SP. Atendimento rápido via WhatsApp."
>
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="text-4xl font-bold">Fale Conosco</h1>
        <p class="mt-4 text-lg text-gray-600">
          Atendimento direto com o responsável. Sem robô, sem espera.
        </p>
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-flex items-center gap-2 rounded-lg bg-green-500 px-8 py-4 text-lg font-semibold text-white hover:bg-green-600"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Abrir WhatsApp
        </a>
      </div>

      <div class="mx-auto mt-16 grid max-w-4xl gap-12 md:grid-cols-2">
        <!-- Info -->
        <div>
          <h2 class="text-xl font-bold">Informações</h2>
          <dl class="mt-6 space-y-4 text-sm text-gray-600">
            <!-- TODO: substituir por dados reais -->
            <div>
              <dt class="font-semibold text-gray-900">Endereço</dt>
              <dd>Rua Exemplo, 123 - Distrito Industrial<br>Americana - SP, 13465-000</dd>
            </div>
            <div>
              <dt class="font-semibold text-gray-900">Telefone / WhatsApp</dt>
              <dd>(19) 99999-9999</dd>
            </div>
            <div>
              <dt class="font-semibold text-gray-900">E-mail</dt>
              <dd>contato@barricas.com.br</dd>
            </div>
            <div>
              <dt class="font-semibold text-gray-900">Horário</dt>
              <dd>Segunda a Sexta, 8h às 17h</dd>
            </div>
          </dl>
        </div>

        <!-- Map placeholder -->
        <div>
          <h2 class="text-xl font-bold">Localização</h2>
          <div class="mt-6 flex h-64 items-center justify-center rounded-xl bg-gray-100 text-sm text-gray-400">
            <!-- TODO: embed Google Maps real -->
            Mapa - Americana, SP
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
