---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/home/Hero.astro";
import TrustBar from "../components/home/TrustBar.astro";
import MetricsStrip from "../components/home/MetricsStrip.astro";
import ProductCards from "../components/home/ProductCards.astro";
import HowItWorks from "../components/home/HowItWorks.astro";
import Testimonials from "../components/home/Testimonials.astro";
import FinalCTA from "../components/home/FinalCTA.astro";
import { company } from "../data/company";

const siteUrl = "https://barricasindustriais.com";

const localBusinessSchema = {
  "@type": "LocalBusiness",
  name: company.name,
  description: `Fabricante industrial de barricas de papelão e baldes plásticos para indústrias de tintas, grafiato e químicos. ${company.city}.`,
  address: {
    "@type": "PostalAddress",
    streetAddress: `${company.address.street} - ${company.address.neighborhood}`,
    addressLocality: company.address.city,
    addressRegion: company.address.state,
    postalCode: company.address.zip,
    addressCountry: company.address.country,
  },
  telephone: company.phone,
  url: siteUrl,
  openingHours: "Mo-Fr 08:00-18:00",
  foundingDate: String(company.foundedYear),
  geo: {
    "@type": "GeoCoordinates",
    latitude: "-22.7394",
    longitude: "-47.3322",
  },
  sameAs: [] as string[],
};

const websiteSchema = {
  "@type": "WebSite",
  name: company.name,
  url: siteUrl,
};

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [localBusinessSchema, websiteSchema],
};
---

<BaseLayout
  title="King Pack · Barricas de Papelão e Baldes Plásticos · Fábrica em Americana SP"
  description="Fábrica de barricas de papelão (14-20L) e baldes plásticos (3,6-20L) para indústrias de tintas, químicos e agroquímicos. Amostra grátis. Americana-SP."
  structuredData={structuredData}
>
  <Hero />
  <TrustBar />
  <MetricsStrip />
  <ProductCards />
  <HowItWorks />
  <Testimonials />
  <FinalCTA />
</BaseLayout>
