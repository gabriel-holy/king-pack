---
const sectors = [
  "Tintas",
  "Grafiato",
  "Vernizes",
  "Químicos",
  "Agroquímicos",
  "Construção Civil",
];
---

<section class="border-y border-border-subtle bg-surface py-6">
  <div class="mx-auto max-w-content px-6">
    <p class="text-center font-body text-sm text-text-muted">
      500+ indústrias já usam nossas embalagens:
      {sectors.map((sector, i) => (
        <>
          <span class="text-text-primary">{sector}</span>
          {i < sectors.length - 1 && " · "}
        </>
      ))}
    </p>
  </div>
</section>
