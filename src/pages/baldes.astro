---
import Layout from "../layouts/Layout.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
---

<Layout
  title="Baldes Plásticos | Embalagens Industriais"
  description="Baldes plásticos de 3,6L a 20L em polipropileno e polietileno. Para tintas, massas, grafiatos e produtos químicos."
>
  <!-- Hero -->
  <section class="bg-brand-900 py-16 text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold">Baldes Plásticos</h1>
      <p class="mt-4 max-w-2xl text-lg text-brand-200">
        Baldes de 3,6L a 20L em polipropileno e polietileno. Alça metálica ou plástica. Para tintas, massas, grafiatos e químicos.
      </p>
    </div>
  </section>

  <!-- Specs Table -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold">Especificações Técnicas</h2>
      <div class="mt-8 overflow-x-auto">
        <table class="w-full text-left text-sm">
          <thead class="border-b border-gray-200 text-gray-500">
            <tr>
              <th class="pb-3 pr-6 font-medium">Modelo</th>
              <th class="pb-3 pr-6 font-medium">Capacidade</th>
              <th class="pb-3 pr-6 font-medium">Material</th>
              <th class="pb-3 pr-6 font-medium">Alça</th>
              <th class="pb-3 font-medium">Tampa</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <!-- TODO: substituir por specs reais -->
            <tr>
              <td class="py-3 pr-6 font-medium">BL-3.6</td>
              <td class="py-3 pr-6">3,6L</td>
              <td class="py-3 pr-6">Polipropileno</td>
              <td class="py-3 pr-6">Plástica</td>
              <td class="py-3">Pressão</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 font-medium">BL-5</td>
              <td class="py-3 pr-6">5L</td>
              <td class="py-3 pr-6">Polipropileno</td>
              <td class="py-3 pr-6">Metálica</td>
              <td class="py-3">Pressão</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 font-medium">BL-10</td>
              <td class="py-3 pr-6">10L</td>
              <td class="py-3 pr-6">Polietileno</td>
              <td class="py-3 pr-6">Metálica</td>
              <td class="py-3">Rosca</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 font-medium">BL-18</td>
              <td class="py-3 pr-6">18L</td>
              <td class="py-3 pr-6">Polietileno</td>
              <td class="py-3 pr-6">Metálica</td>
              <td class="py-3">Pressão</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 font-medium">BL-20</td>
              <td class="py-3 pr-6">20L</td>
              <td class="py-3 pr-6">Polietileno</td>
              <td class="py-3 pr-6">Metálica</td>
              <td class="py-3">Pressão / Rosca</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Applications -->
  <section class="bg-gray-50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold">Aplicações</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl bg-white p-6 shadow-sm">
          <h3 class="font-bold">Tintas e Massas</h3>
          <p class="mt-2 text-sm text-gray-600">Baldes com vedação hermética para tintas látex, acrílicas e massas corridas.</p>
        </div>
        <div class="rounded-xl bg-white p-6 shadow-sm">
          <h3 class="font-bold">Grafiatos e Texturas</h3>
          <p class="mt-2 text-sm text-gray-600">Resistência a materiais abrasivos. Tampa de pressão para fácil abertura na obra.</p>
        </div>
        <div class="rounded-xl bg-white p-6 shadow-sm">
          <h3 class="font-bold">Químicos Industriais</h3>
          <p class="mt-2 text-sm text-gray-600">Polietileno de alta densidade para produtos com pH extremo.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-800 py-16 text-white">
    <div class="mx-auto max-w-4xl px-4 text-center">
      <h2 class="text-3xl font-bold">Precisa de baldes para sua produção?</h2>
      <p class="mt-4 text-brand-200">Volume, material e tipo de tampa sob medida. Orçamento rápido.</p>
      <WhatsAppButton message="Olá! Gostaria de saber mais sobre os baldes plásticos." label="Pedir Orçamento pelo WhatsApp" size="lg" class="mt-8" />
    </div>
  </section>
</Layout>
