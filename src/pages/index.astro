---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/home/Hero.astro";
import TrustBar from "../components/home/TrustBar.astro";
import MetricsStrip from "../components/home/MetricsStrip.astro";
import ProductCards from "../components/home/ProductCards.astro";
import HowItWorks from "../components/home/HowItWorks.astro";
import Testimonials from "../components/home/Testimonials.astro";
import FinalCTA from "../components/home/FinalCTA.astro";
import { company } from "../data/company";
import { testimonials } from "../data/testimonials";

const siteUrl = "https://barricasindustriais.com";

const localBusinessSchema = {
  "@type": "LocalBusiness",
  name: company.name,
  description: `Fabricante industrial de barricas de papelão e baldes plásticos para indústrias de tintas, grafiato e químicos. ${company.city}.`,
  address: {
    "@type": "PostalAddress",
    streetAddress: `${company.address.street} - ${company.address.neighborhood}`,
    addressLocality: company.address.city,
    addressRegion: company.address.state,
    postalCode: company.address.zip,
    addressCountry: company.address.country,
  },
  telephone: company.phone,
  url: siteUrl,
  openingHours: "Mo-Fr 08:00-18:00",
  foundingDate: String(company.foundedYear),
  geo: {
    "@type": "GeoCoordinates",
    latitude: "-22.7394",
    longitude: "-47.3322",
  },
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "5",
    reviewCount: String(testimonials.length),
  },
  review: testimonials.map((t) => ({
    "@type": "Review",
    author: { "@type": "Person", name: t.author },
    reviewBody: t.quote,
    reviewRating: { "@type": "Rating", ratingValue: "5" },
  })),
};

const websiteSchema = {
  "@type": "WebSite",
  name: company.name,
  url: siteUrl,
};

const howToSchema = {
  "@type": "HowTo",
  name: "Como trocar de fornecedor de embalagens sem risco",
  step: [
    {
      "@type": "HowToStep",
      position: 1,
      name: "Peça sua amostra grátis",
      text: "Manda um WhatsApp com o produto e o volume. A gente responde em até 2 horas.",
    },
    {
      "@type": "HowToStep",
      position: 2,
      name: "Teste na sua linha",
      text: "Amostra grátis entregue em até 48h. Você testa no seu processo real.",
    },
    {
      "@type": "HowToStep",
      position: 3,
      name: "Aprovou? A produção começa",
      text: "Produção sob medida em 7 a 10 dias úteis. Lotes a partir de 200 unidades com entrega em SP.",
    },
  ],
};

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [localBusinessSchema, websiteSchema, howToSchema],
};
---

<BaseLayout
  title="King Pack · Barricas de Papelão e Baldes Plásticos · Fábrica em Americana SP"
  description="Fábrica de barricas de papelão (14-20L) e baldes plásticos (3,6-20L) para indústrias de tintas, químicos e agroquímicos. Amostra grátis. Americana-SP."
  structuredData={structuredData}
>
  <Hero />
  <TrustBar />
  <MetricsStrip />
  <ProductCards />
  <HowItWorks />
  <Testimonials />
  <FinalCTA />
</BaseLayout>
