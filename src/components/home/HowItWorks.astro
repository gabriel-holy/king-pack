---
import SectionHeader from "../shared/SectionHeader.astro";

const steps = [
  {
    number: 1,
    title: "Peça sua amostra grátis",
    description: "Manda um WhatsApp com o produto e o volume. A gente responde em até 2 horas.",
  },
  {
    number: 2,
    title: "Teste na sua linha",
    description: "Amostra grátis entregue em até 48h. Você testa no seu processo real — sem surpresas depois.",
  },
  {
    number: 3,
    title: "Aprovou? Produção imediata",
    description: "Produção sob medida em 7 a 10 dias úteis. Lotes a partir de 200 unidades com entrega em SP.",
  },
];
---

<section class="bg-bg py-16">
  <div class="mx-auto max-w-content px-6">
    <SectionHeader title="3 passos para trocar de fornecedor sem risco" />
    <div class="mt-12 grid gap-8 sm:grid-cols-3">
      {steps.map((step) => (
        <div class="text-center">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-lg bg-surface font-heading text-xl font-bold text-accent">
            {step.number}
          </div>
          <h3 class="mt-4 font-heading text-lg font-semibold text-text-primary">{step.title}</h3>
          <p class="mt-2 font-body text-sm text-text-muted">
            {step.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
