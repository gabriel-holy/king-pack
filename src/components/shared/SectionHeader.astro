---
interface Props {
  title: string;
  subtitle?: string;
  class?: string;
}

const { title, subtitle, class: className = "" } = Astro.props;
---

<div class:list={["text-center", className]}>
  <h2 class="font-heading text-3xl font-semibold tracking-snug text-text-primary">
    {title}
  </h2>
  {subtitle && (
    <p class="mx-auto mt-4 max-w-text font-body text-text-muted">
      {subtitle}
    </p>
  )}
</div>
